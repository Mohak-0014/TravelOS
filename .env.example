# LLM
ANTHROPIC_API_KEY=

# Database / cache / vectors
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/travelos
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Hotel APIs
LITEAPI_KEY=
HOTELSNL_API_KEY=

# Other free APIs (Open-Meteo + Nominatim + OSM tiles need NO key)
OPENTRIPMAP_API_KEY=
FOURSQUARE_API_KEY=

# Auth — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# App
ENVIRONMENT=development
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:3000"]
