# LLM
GROQ_API_KEY=gsk_your_key_here

# Database / cache / vectors
# Note: Docker postgres is on port 5433 (Windows native pg owns 5432)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/travelos
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
QDRANT_HOST=localhost
QDRANT_PORT=6333
# Required when Qdrant is network-exposed (production) — must match
# QDRANT__SERVICE__API_KEY in docker-compose.prod.yml. Leave blank for local Docker.
QDRANT_API_KEY=

# Hotel APIs
LITEAPI_KEY=
HOTELSNL_API_KEY=

# Restaurants (key required)
FOURSQUARE_API_KEY=

# Events APIs
TICKETMASTER_API_KEY=
EVENTBRITE_TOKEN=

# Flight prices — Duffel (free sandbox at app.duffel.com)
DUFFEL_API_KEY=

# Destination photos — optional, trips fall back to gradient if unset
UNSPLASH_ACCESS_KEY=

# Free APIs — no key needed:
# Open-Meteo (weather), Nominatim (geocoding), Overpass API (attractions), OSM tiles

# Auth — generate with: openssl rand -hex 32
# REQUIRED in production: the app refuses to boot if this is unset or weak (<32 chars).
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# App
ENVIRONMENT=development
LOG_LEVEL=INFO
# In production set CORS_ORIGINS to your real frontend origin(s) — never "*".
CORS_ORIGINS=["http://localhost:3000"]
# Per-IP rate limiting on auth endpoints (needs REDIS_URL reachable). Disable only for local tests.
RATE_LIMIT_ENABLED=true
# Retry + circuit breaker on outbound provider calls (Nominatim, Duffel, LiteAPI, …).
RESILIENCE_ENABLED=true

# Error tracking (optional — no Sentry events without this)
SENTRY_DSN=

# Prod-only secrets (not needed for local dev)
# POSTGRES_PASSWORD=
# REDIS_PASSWORD=
