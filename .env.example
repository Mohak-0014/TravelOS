# LLM
GROQ_API_KEY=gsk_your_key_here

# Database / cache / vectors
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/travelos
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Hotel APIs
LITEAPI_KEY=
HOTELSNL_API_KEY=

# Restaurants (key required)
FOURSQUARE_API_KEY=

# Events APIs
TICKETMASTER_API_KEY=
EVENTBRITE_TOKEN=

# Flight prices — Amadeus sandbox (free at developers.amadeus.com)
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=

# Destination photos — optional, trips fall back to gradient if unset
UNSPLASH_ACCESS_KEY=

# Free APIs — no key needed:
# Open-Meteo (weather), Nominatim (geocoding), Overpass API (attractions), OSM tiles

# Auth — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# App
ENVIRONMENT=development
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:3000"]
