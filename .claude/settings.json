{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -File .claude/hooks/ruff-format.ps1",
            "timeout": 10,
            "statusMessage": "Formatting Python..."
          }
        ]
      }
    ]
  }
}
